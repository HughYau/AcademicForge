---
import '../styles/global.css';
import ForgeLogo from '../components/ForgeLogo.astro';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Browse star-ranked AI skill repositories and generate install commands for Claude Code, OpenCode, or Codex.',
} = Astro.props;

const baseUrl = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const faviconHref = `${baseUrl}favicon.svg`;
const githubRepo = 'HughYau/AcademicForge';
const githubUrl = `https://github.com/${githubRepo}`;
const githubStarBadge = `https://img.shields.io/github/stars/${githubRepo}?style=social`;
---

<!doctype html>
<html lang="en" data-lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&family=Noto+Serif+SC:wght@400;500;600;700&family=Roboto+Slab:wght@400;500;700&display=swap" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&family=Noto+Serif+SC:wght@400;500;600;700&family=Roboto+Slab:wght@400;500;700&display=swap" />
    <link rel="icon" type="image/svg+xml" href={faviconHref} />
    <title>{title}</title>
  </head>
  <body class="min-h-screen antialiased">
    <div class="min-h-screen">
      <header class="sticky top-0 z-40 border-b border-[#e8e6dc]/90 bg-[rgba(245,244,237,0.9)] backdrop-blur-xl">
        <div class="mx-auto flex max-w-[1680px] items-center justify-between gap-4 px-4 py-5 sm:px-6">
          <a href="#home" class="flex min-w-0 items-center gap-3 text-[#141413]">
            <span class="inline-flex h-11 w-11 shrink-0 items-center justify-center rounded-xl border border-[#e8e6dc] bg-white shadow-[0_0_0_1px_#f0eee6]">
              <ForgeLogo class="h-8 w-8" title="AcademicForge" />
            </span>

            <span class="min-w-0">
              <span class="block truncate font-slab text-xl leading-none tracking-tight text-oxford">
                Academic<span class="font-bold text-forgegold">Forge</span>
              </span>
              <span class="hidden truncate text-xs text-[#87867f] md:block">
                <span class="lang-en">One Forge, All Skills.</span>
                <span class="lang-zh font-cjk font-bold">一站在手，万技我有。</span>
              </span>
            </span>
          </a>

          <div class="flex items-center gap-4">
            <a
              href={githubUrl}
              class="hidden items-center gap-2 rounded-full border border-[#d9d6c9] bg-white px-3 py-1.5 text-sm text-[#4d4c48] shadow-[0_0_0_1px_#f0eee6] transition hover:border-[#c9c6b8] hover:bg-[#faf9f5] md:inline-flex"
              target="_blank"
              rel="noreferrer"
            >
              <span class="lang-en">Star on GitHub</span>
              <span class="lang-zh">去 GitHub 点赞</span>
              <img src={githubStarBadge} alt="AcademicForge stars on GitHub" class="h-5 w-auto" loading="lazy" decoding="async" />
            </a>

            <div class="locale-switch inline-flex items-center rounded-full p-1">
              <button type="button" class="locale-toggle rounded-full px-3 py-2 text-sm font-medium" data-set-locale="en" aria-pressed="true">
                EN
              </button>
              <button type="button" class="locale-toggle rounded-full px-3 py-2 text-sm font-medium" data-set-locale="zh" aria-pressed="false">
                中文
              </button>
            </div>
          </div>
        </div>
      </header>

      <slot />
    </div>

    <script>
      const root = document.documentElement;
      const localeButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-set-locale]'));

      const setLocale = (locale: 'en' | 'zh') => {
        root.dataset.lang = locale;
        root.lang = locale === 'zh' ? 'zh-CN' : 'en';

        localeButtons.forEach((button) => {
          const isActive = button.dataset.setLocale === locale;
          button.setAttribute('aria-pressed', String(isActive));
        });

        window.dispatchEvent(new CustomEvent('academicforge:locale-change', {
          detail: { locale },
        }));
      };

      localeButtons.forEach((button) => {
        button.addEventListener('click', () => {
          setLocale(button.dataset.setLocale === 'zh' ? 'zh' : 'en');
        });
      });

      setLocale(root.dataset.lang === 'zh' ? 'zh' : 'en');
    </script>
  </body>
</html>
