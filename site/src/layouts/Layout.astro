---
import '../styles/global.css';
import ForgeLogo from '../components/ForgeLogo.astro';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Browse academic AI skill repositories and generate install commands for Claude Code, OpenCode, or Codex.',
} = Astro.props;

const baseUrl = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const faviconHref = `${baseUrl}favicon.svg`;
const agentsHref = `${baseUrl}agents.md`;
const canonicalUrl = `https://hughyau.github.io${baseUrl}`;
const ogImageHref = `${baseUrl}og-image.svg`;
const googleAnalyticsId = 'G-R67NC4FQJ1';
const githubRepo = 'HughYau/AcademicForge';
const githubUrl = `https://github.com/${githubRepo}`;
const githubStarBadge = `https://img.shields.io/github/stars/${githubRepo}?style=social`;
---

<!doctype html>
<html lang="en" data-lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageHref} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageHref} />
    <script async src={`https://www.googletagmanager.com/gtag/js?id=${googleAnalyticsId}`}></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-R67NC4FQJ1');
    </script>
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&family=Noto+Serif+SC:wght@400;500;600;700&family=Roboto+Slab:wght@400;500;700&display=swap" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&family=Noto+Serif+SC:wght@400;500;600;700&family=Roboto+Slab:wght@400;500;700&display=swap" />
    <link rel="icon" type="image/svg+xml" href={faviconHref} />
    <title>{title}</title>
  </head>
  <body class="min-h-screen antialiased">
    <div class="min-h-screen">
      <header class="sticky inset-x-0 top-0 z-40 border-b border-[#e8e6dc]/90 bg-[rgba(245,244,237,0.9)] backdrop-blur-xl">
        <div class="mx-auto flex w-full min-w-0 items-center justify-between gap-3 px-4 py-4 sm:w-[92%] sm:px-0 sm:gap-4 sm:py-5 lg:w-[90%] lg:py-6">
          <a href="#home" class="flex min-w-0 items-center gap-3 text-[#141413] sm:gap-4">
            <span class="inline-flex h-12 w-12 shrink-0 items-center justify-center rounded-xl border border-[#e8e6dc] bg-white shadow-[0_0_0_1px_#f0eee6] lg:h-[3.25rem] lg:w-[3.25rem]">
              <ForgeLogo class="h-9 w-9" title="AcademicForge" />
            </span>

            <span class="min-w-0 space-y-0.5">
              <span class="block truncate font-slab text-[1.35rem] leading-[1.15] tracking-[-0.01em] text-oxford lg:text-[1.55rem]">
                Academic<span class="font-bold text-forgegold">Forge</span>
              </span>
              <span class="hidden truncate text-sm text-[#87867f] md:block">
                <span class="lang-en">One Forge, All Skills.</span>
                <span class="lang-zh font-cjk font-bold">一站在手，万技我有。</span>
              </span>
            </span>
          </a>

          <div class="flex items-center gap-2 sm:gap-4">
            <div class="flex items-center gap-1.5">
              <button
                type="button"
                id="ai-prompt-copy"
                class="ai-pick__button ai-pick__button--header"
                data-label-en="Not sure? Ask your AI"
                data-label-zh="不知道选什么？让 AI 帮我选"
                data-copied-en="✓ Forged — paste it to your AI"
                data-copied-zh="✓ 已锻好——去粘贴给你的 AI"
              >
                <svg viewBox="0 0 20 20" fill="none" class="h-4 w-4 shrink-0" aria-hidden="true">
                  <path d="M10 2c.6 3.2 1.9 4.5 5 5-3.1.5-4.4 1.8-5 5-.6-3.2-1.9-4.5-5-5 3.1-.5 4.4-1.8 5-5Z" fill="currentColor"></path>
                  <path d="M15.5 11.5c.35 1.9 1.1 2.65 3 3-1.9.35-2.65 1.1-3 3-.35-1.9-1.1-2.65-3-3 1.9-.35 2.65-1.1 3-3Z" fill="currentColor" opacity="0.7"></path>
                  <path d="M4.5 12.5c.3 1.6.9 2.2 2.5 2.5-1.6.3-2.2.9-2.5 2.5-.3-1.6-.9-2.2-2.5-2.5 1.6-.3 2.2-.9 2.5-2.5Z" fill="currentColor" opacity="0.5"></path>
                </svg>
                <span id="ai-prompt-copy-label" class="truncate">Not sure? Ask your AI</span>
              </button>
              <a
                href={agentsHref}
                target="_blank"
                rel="noreferrer"
                class="ai-pick__link ai-pick__link--icon"
                data-title-en="What will your AI read?"
                data-title-zh="它会读到什么？"
                title="What will your AI read?"
                aria-label="What will your AI read?"
              >
                <svg viewBox="0 0 16 16" fill="none" class="h-3.5 w-3.5" aria-hidden="true">
                  <path d="M6 6a2 2 0 1 1 3.2 1.6c-.7.5-1.2 1-1.2 1.9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></path>
                  <circle cx="8" cy="12" r="0.9" fill="currentColor"></circle>
                </svg>
              </a>
            </div>

            <a
              href={githubUrl}
              class="hidden items-center gap-2 rounded-full border border-[#d9d6c9] bg-white px-3 py-1.5 text-sm text-[#4d4c48] shadow-[0_0_0_1px_#f0eee6] transition hover:border-[#c9c6b8] hover:bg-[#faf9f5] md:inline-flex"
              target="_blank"
              rel="noreferrer"
            >
              <span class="lang-en">Star on GitHub</span>
              <span class="lang-zh">去 GitHub 点赞</span>
              <img src={githubStarBadge} alt="AcademicForge stars on GitHub" class="h-5 w-auto" loading="lazy" decoding="async" />
            </a>

            <div class="locale-switch inline-flex items-center rounded-full p-1">
              <button type="button" class="locale-toggle rounded-full px-3 py-2 text-sm font-medium" data-set-locale="en" aria-pressed="true">
                EN
              </button>
              <button type="button" class="locale-toggle rounded-full px-3 py-2 text-sm font-medium" data-set-locale="zh" aria-pressed="false">
                中文
              </button>
            </div>
          </div>
        </div>
      </header>

      <slot />
    </div>

    <script>
      const root = document.documentElement;
      const localeButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-set-locale]'));

      const setLocale = (locale: 'en' | 'zh') => {
        root.dataset.lang = locale;
        root.lang = locale === 'zh' ? 'zh-CN' : 'en';

        document.querySelectorAll<HTMLElement>('[data-title-en]').forEach((element) => {
          const title = locale === 'zh' ? element.dataset.titleZh ?? '' : element.dataset.titleEn ?? '';
          if (title) {
            element.title = title;
            element.setAttribute('aria-label', title);
          }
        });

        localeButtons.forEach((button) => {
          const isActive = button.dataset.setLocale === locale;
          button.setAttribute('aria-pressed', String(isActive));
        });

        window.dispatchEvent(new CustomEvent('academicforge:locale-change', {
          detail: { locale },
        }));
      };

      localeButtons.forEach((button) => {
        button.addEventListener('click', () => {
          setLocale(button.dataset.setLocale === 'zh' ? 'zh' : 'en');
        });
      });

      setLocale(root.dataset.lang === 'zh' ? 'zh' : 'en');
    </script>
  </body>
</html>
