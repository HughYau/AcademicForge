---
import { readFileSync } from 'node:fs';
import { resolve } from 'node:path';
import Configurator from '../components/Configurator.astro';
import SkillGrid from '../components/SkillGrid.astro';
import { sortSkillsByStars } from '../lib/registry';
import type { RegistryData } from '../lib/registry';
import Layout from '../layouts/Layout.astro';

const registryPath = resolve(process.cwd(), '../registry/skills.json');
const registry = JSON.parse(readFileSync(registryPath, 'utf-8')) as RegistryData;
const skills = sortSkillsByStars(registry.skills);
const repositoryCount = skills.length;
const totalSkillCount = skills.reduce((sum, skill) => sum + skill.skill_count, 0);
---

<Layout
  title="AcademicForge | One Forge, All Skills"
  description="Browse academic AI skill repositories and generate install commands for Claude Code, OpenCode, or Codex."
>
  <main id="home" class="mx-auto flex w-[80%] min-h-0 flex-col gap-4 py-4 sm:py-5 lg:h-[calc(100svh-92px)] lg:overflow-hidden lg:py-6">
    <section class="grid min-h-0 flex-1 gap-4 lg:h-[90%] lg:w-full lg:self-center lg:flex-none lg:grid-cols-[minmax(0,1.42fr)_390px] xl:grid-cols-[minmax(0,1.55fr)_405px]">
      <SkillGrid skills={skills} repositoryCount={repositoryCount} totalSkillCount={totalSkillCount} />
      <Configurator />
    </section>
  </main>
</Layout>
