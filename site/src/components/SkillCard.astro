---
import { formatCount } from '../lib/registry';
import type { LocalizedText } from '../lib/registry';

interface Props {
  id: string;
  name: string;
  summary: LocalizedText;
  author: string;
  repository: string;
  license: string;
  skill_count: number;
  stars: number;
  tags: string[];
  rank: number;
}

const { id, name, summary, author, repository, skill_count, stars, tags, rank } = Astro.props;
const searchText = [name, summary.en, summary.zh, author, ...tags].join(' ').toLowerCase();
---

<article
  class:list={[
    'skill-card flex items-center gap-3 px-4 py-3 transition sm:gap-4 sm:px-5',
    rank === 1 ? '' : 'border-t border-[#e8e6dc]',
  ]}
  data-skill-id={id}
  data-search={searchText}
>
  <label class="inline-flex shrink-0 cursor-pointer items-center">
    <input
      type="checkbox"
      class="skill-checkbox peer sr-only"
      aria-label={`Select ${name}`}
      data-skill-id={id}
      data-skill-name={name}
      data-skill-count={String(skill_count)}
    />
    <span class="flex h-8 w-8 items-center justify-center rounded-[12px] border border-[#d1cfc5] bg-white text-transparent shadow-[0_0_0_1px_#f0eee6] transition peer-checked:border-[#c96442] peer-checked:bg-[#c96442] peer-checked:text-[#faf9f5]">
      <svg viewBox="0 0 20 20" fill="none" class="h-4 w-4" aria-hidden="true">
        <path d="M4.5 10.5 8 14l7.5-8" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"></path>
      </svg>
    </span>
  </label>

  <div class="min-w-0 flex-1">
    <div class="flex min-w-0 items-center gap-2">
      <h3 class="truncate text-[1.08rem] leading-tight text-[#141413] sm:text-[1.16rem]">{name}</h3>
      <a
        href={repository}
        target="_blank"
        rel="noreferrer"
        class="hidden truncate text-xs text-[#87867f] underline decoration-[#d1cfc5] underline-offset-4 hover:text-[#141413] sm:inline"
      >
        @{author}
      </a>
    </div>
    <p class="compact-clamp mt-1 text-sm leading-6 text-[#5e5d59]">
      <span class="lang-en">{summary.en}</span>
      <span class="lang-zh">{summary.zh}</span>
    </p>
  </div>

  <div class="shrink-0 text-right text-xs leading-5 text-[#87867f] sm:text-sm">
    <p>{formatCount(stars)}<span class="hidden sm:inline"> stars</span></p>
    <p>{formatCount(skill_count)}<span class="hidden sm:inline"> skills</span></p>
  </div>
</article>
