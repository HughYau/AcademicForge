---
import { CATEGORY_LABELS, CATEGORY_ORDER, SUBDISCIPLINE_LABELS, SUBDISCIPLINE_ORDER, getItemCategory } from '../lib/categories';
import type { Category, Subdiscipline } from '../lib/categories';
import { formatCount } from '../lib/registry';
import type { SkillRecord, SubSkillRecord } from '../lib/registry';
import SkillCard from './SkillCard.astro';

interface Props {
  skills: SkillRecord[];
  repositoryCount: number;
  totalSkillCount: number;
}

const { skills, repositoryCount, totalSkillCount } = Astro.props;

const sortSubSkills = (items: SubSkillRecord[]) => {
  return [...items].sort((left, right) => left.name.localeCompare(right.name));
};

const rootSkillsByCategory = Object.fromEntries(
  CATEGORY_ORDER.map((category) => [category, [] as SkillRecord[]]),
) as Record<Category, SkillRecord[]>;

const directSubSkillsByCategory = Object.fromEntries(
  CATEGORY_ORDER.map((category) => [category, [] as SubSkillRecord[]]),
) as Record<Category, SubSkillRecord[]>;

const researchSubSkillsBySubdiscipline = Object.fromEntries(
  SUBDISCIPLINE_ORDER.map((subdiscipline) => [subdiscipline, [] as SubSkillRecord[]]),
) as Record<Subdiscipline, SubSkillRecord[]>;

skills.forEach((skill) => {
  rootSkillsByCategory[getItemCategory(skill)].push(skill);

  skill.sub_skills?.forEach((subSkill) => {
    const category = getItemCategory(subSkill);
    if (category === 'research' && subSkill.subdiscipline) {
      researchSubSkillsBySubdiscipline[subSkill.subdiscipline as Subdiscipline].push(subSkill);
      return;
    }

    directSubSkillsByCategory[category].push(subSkill);
  });
});

for (const category of CATEGORY_ORDER) {
  directSubSkillsByCategory[category] = sortSubSkills(directSubSkillsByCategory[category]);
}

for (const subdiscipline of SUBDISCIPLINE_ORDER) {
  researchSubSkillsBySubdiscipline[subdiscipline] = sortSubSkills(researchSubSkillsBySubdiscipline[subdiscipline]);
}

const categoryItemCounts = Object.fromEntries(
  CATEGORY_ORDER.map((category) => {
    const nestedResearchCount = category === 'research'
      ? SUBDISCIPLINE_ORDER.reduce((sum, subdiscipline) => sum + researchSubSkillsBySubdiscipline[subdiscipline].length, 0)
      : 0;

    return [
      category,
      rootSkillsByCategory[category].length + directSubSkillsByCategory[category].length + nestedResearchCount,
    ];
  }),
) as Record<Category, number>;

const visibleCategories = CATEGORY_ORDER.filter((category) => categoryItemCounts[category] > 0);
const initialCategory = visibleCategories[0] ?? 'workflow';
const visibleResearchSubdisciplines = SUBDISCIPLINE_ORDER.filter((subdiscipline) => researchSubSkillsBySubdiscipline[subdiscipline].length > 0);
---

<section id="library" class="flex min-h-0 flex-col rounded-[28px] border border-[#e8e6dc] bg-[#faf9f5] p-4 shadow-[0_10px_30px_rgba(20,20,19,0.05)] sm:p-5">
  <div class="flex flex-col gap-3 border-b border-[#e8e6dc] pb-4 lg:flex-row lg:items-end lg:justify-between">
    <div class="space-y-2">
      <p class="text-[11px] font-semibold uppercase tracking-[0.24em] text-[#c96442]">
        <span class="lang-en">Repositories</span>
        <span class="lang-zh">仓库目录</span>
      </p>
      <h1 class="font-slab text-[2rem] leading-[1.05] text-[#141413] sm:text-[2.4rem] lg:text-[2.8rem]">
        <span class="lang-en">Pick what you need.</span>
        <span class="lang-zh">只选你用得上的。</span>
      </h1>
      <div class="flex flex-wrap gap-2 text-xs text-[#5e5d59] sm:text-sm">
        <span class="rounded-full bg-white px-3 py-1.5 shadow-[0_0_0_1px_#f0eee6]">
          <span class="lang-en">{formatCount(repositoryCount)} repositories</span>
          <span class="lang-zh">共 {formatCount(repositoryCount)} 个仓库</span>
        </span>
        <span class="rounded-full bg-white px-3 py-1.5 shadow-[0_0_0_1px_#f0eee6]">
          <span class="lang-en">{formatCount(totalSkillCount)} skills</span>
          <span class="lang-zh">共 {formatCount(totalSkillCount)} 个 skill</span>
        </span>
        <span class="rounded-full bg-white px-3 py-1.5 shadow-[0_0_0_1px_#f0eee6]">
          <span class="lang-en">sorted by stars</span>
          <span class="lang-zh">按 star 排序</span>
        </span>
      </div>
    </div>

    <label class="block w-full lg:max-w-sm">
      <span class="sr-only">Search repositories</span>
      <input
        id="skill-search"
        type="search"
        placeholder="Search repositories / authors / tags"
        class="w-full rounded-[16px] border border-[#e8e6dc] bg-white px-4 py-3 text-sm text-[#141413] outline-none placeholder:text-[#87867f] focus:border-[#3898ec] focus:shadow-[0_0_0_1px_#3898ec]"
      />
    </label>
  </div>

  <div class="category-tabs mt-3" role="tablist" aria-label="Top-level skill categories">
    {visibleCategories.map((category) => (
      <button
        type="button"
        class="category-tab"
        role="tab"
        data-category-tab={category}
        aria-selected={category === initialCategory}
        aria-pressed={category === initialCategory}
      >
        <span class="lang-en">{CATEGORY_LABELS[category].en}</span>
        <span class="lang-zh">{CATEGORY_LABELS[category].zh}</span>
      </button>
    ))}
  </div>

  <div id="skill-grid" class="mt-3 min-h-0 flex-1 overflow-y-auto rounded-[22px] bg-white p-3 shadow-[0_0_0_1px_#f0eee6] sm:p-4">
    {visibleCategories.map((category) => (
      <section class:list={['skill-panel space-y-3', category === initialCategory ? '' : 'hidden']} data-category-panel={category}>
        {rootSkillsByCategory[category].length > 0 && (
          <div class="skill-card-grid">
            {rootSkillsByCategory[category].map((skill, index) => (
              <SkillCard {...skill} rank={index + 1} />
            ))}
          </div>
        )}

        {directSubSkillsByCategory[category].length > 0 && (
          <div class="skill-card-grid skill-card-grid--dense">
            {directSubSkillsByCategory[category].map((skill, index) => (
              <SkillCard {...skill} compact rank={index + 1} />
            ))}
          </div>
        )}

        {category === 'research' && visibleResearchSubdisciplines.length > 0 && (
          <div class="space-y-2">
            {visibleResearchSubdisciplines.map((subdiscipline) => (
              <details
                class="skill-group skill-group--sub rounded-[18px] border border-[#e8e6dc] bg-[#faf9f5]"
                data-category={`${category}-${subdiscipline}`}
                data-user-open="false"
              >
                <summary class="details-summary px-3.5 py-2.5">
                  <p class="font-slab text-sm font-medium text-[#141413]">
                    <span aria-hidden="true">{SUBDISCIPLINE_LABELS[subdiscipline].icon}</span>
                    <span class="ml-2 lang-en">{SUBDISCIPLINE_LABELS[subdiscipline].en}</span>
                    <span class="ml-2 lang-zh">{SUBDISCIPLINE_LABELS[subdiscipline].zh}</span>
                  </p>

                  <span class="flex items-center gap-2 text-xs text-[#87867f]">
                    <span>{formatCount(researchSubSkillsBySubdiscipline[subdiscipline].length)}</span>
                    <svg viewBox="0 0 16 16" fill="none" class="chevron-icon" aria-hidden="true">
                      <path d="M3.5 6 8 10.5 12.5 6" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6"></path>
                    </svg>
                  </span>
                </summary>

                <div class="details-body">
                  <div class="details-body__inner border-t border-[#f0eee6] bg-white p-3 sm:p-4">
                    <div class="skill-card-grid skill-card-grid--dense">
                      {researchSubSkillsBySubdiscipline[subdiscipline].map((skill, index) => (
                        <SkillCard {...skill} compact rank={index + 1} />
                      ))}
                    </div>
                  </div>
                </div>
              </details>
            ))}
          </div>
        )}
      </section>
    ))}
  </div>

  <div id="skill-grid-empty" class="hidden rounded-[22px] bg-white px-6 py-10 text-center text-[#87867f] shadow-[0_0_0_1px_#f0eee6]"></div>
</section>

<script>
  const skillCards = Array.from(document.querySelectorAll<HTMLElement>('.skill-card'));
  const skillGroups = Array.from(document.querySelectorAll<HTMLDetailsElement>('.skill-group--sub'));
  const categoryTabs = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-category-tab]'));
  const categoryPanels = Array.from(document.querySelectorAll<HTMLElement>('[data-category-panel]'));
  const searchInput = document.getElementById('skill-search') as HTMLInputElement | null;
  const emptyState = document.getElementById('skill-grid-empty');
  const grid = document.getElementById('skill-grid');

  const translations = {
    en: {
      placeholder: 'Search repositories / authors / tags',
      empty: 'No matching repositories.',
    },
    zh: {
      placeholder: '搜索仓库 / 作者 / 标签',
      empty: '无匹配结果。',
    },
  };

  let visibleCount = skillCards.length;
  let activeCategory = categoryTabs.find((button) => button.getAttribute('aria-pressed') === 'true')?.dataset.categoryTab
    ?? categoryTabs[0]?.dataset.categoryTab
    ?? '';

  const getLocale = () => document.documentElement.dataset.lang === 'zh' ? 'zh' : 'en';

  const getActivePanel = () => {
    return categoryPanels.find((panel) => panel.dataset.categoryPanel === activeCategory) ?? null;
  };

  const applyTabState = () => {
    categoryTabs.forEach((button) => {
      const isActive = button.dataset.categoryTab === activeCategory;
      button.setAttribute('aria-selected', String(isActive));
      button.setAttribute('aria-pressed', String(isActive));
    });

    categoryPanels.forEach((panel) => {
      panel.classList.toggle('hidden', panel.dataset.categoryPanel !== activeCategory);
    });
  };

  const updateCardSelectionState = (checkbox: HTMLInputElement) => {
    const card = checkbox.closest('.skill-card');
    if (!(card instanceof HTMLElement)) {
      return;
    }

    card.classList.toggle('is-selected', checkbox.checked);
  };

  const setCardDetailState = (card: HTMLElement, expanded: boolean) => {
    card.classList.toggle('is-expanded', expanded);

    const toggle = card.querySelector<HTMLButtonElement>('.skill-card__toggle');
    const detail = card.querySelector<HTMLElement>('.skill-card__detail-panel');

    toggle?.setAttribute('aria-expanded', String(expanded));

    if (detail) {
      detail.setAttribute('aria-hidden', String(!expanded));
      detail.toggleAttribute('inert', !expanded);
    }
  };

  const toggleCardDetail = (card: HTMLElement) => {
    setCardDetailState(card, !card.classList.contains('is-expanded'));
  };

  const applyLocale = () => {
    const locale = getLocale();

    if (searchInput) {
      searchInput.placeholder = translations[locale].placeholder;
    }

    if (emptyState && visibleCount === 0) {
      emptyState.textContent = translations[locale].empty;
    }
  };

  const applyFilters = () => {
    const query = searchInput?.value.trim().toLowerCase() ?? '';
    const hasQuery = query.length > 0;
    visibleCount = 0;

    skillCards.forEach((card) => {
      const search = card.dataset.search ?? '';
      const isVisible = !query || search.includes(query);

      card.classList.toggle('hidden', !isVisible);
      if (isVisible) {
        visibleCount += 1;
      }
    });

    skillGroups.forEach((group) => {
      const visibleCards = Array.from(group.querySelectorAll<HTMLElement>('.skill-card')).filter((card) => !card.classList.contains('hidden'));
      const hasVisible = visibleCards.length > 0;

      group.hidden = !hasVisible;
      group.open = hasQuery ? hasVisible : group.dataset.userOpen === 'true';
    });

    applyTabState();

    const activePanel = getActivePanel();
    const hasVisible = activePanel
      ? Array.from(activePanel.querySelectorAll<HTMLElement>('.skill-card')).some((card) => !card.classList.contains('hidden'))
      : false;

    emptyState?.classList.toggle('hidden', hasVisible);
    grid?.classList.toggle('hidden', !hasVisible);

    if (emptyState && !hasVisible) {
      emptyState.textContent = translations[getLocale()].empty;
    }
  };

  searchInput?.addEventListener('input', applyFilters);

  categoryTabs.forEach((button) => {
    button.addEventListener('click', () => {
      activeCategory = button.dataset.categoryTab ?? activeCategory;
      applyFilters();
    });
  });

  skillGroups.forEach((group) => {
    group.dataset.userOpen = String(group.open);
    group.addEventListener('toggle', () => {
      if ((searchInput?.value.trim() ?? '') === '') {
        group.dataset.userOpen = String(group.open);
      }
    });
  });

  document.addEventListener('click', (event) => {
    const target = event.target;
    if (!(target instanceof HTMLElement)) {
      return;
    }

    const toggle = target.closest('.skill-card__toggle');
    if (toggle instanceof HTMLButtonElement) {
      const card = toggle.closest('.skill-card');
      if (card instanceof HTMLElement) {
        toggleCardDetail(card);
      }
      return;
    }

    if (target.closest('a, button, input, label, summary')) {
      return;
    }

    const surface = target.closest<HTMLElement>('[data-detail-toggle]');
    if (!(surface instanceof HTMLElement)) {
      return;
    }

    const card = surface.closest('.skill-card');
    if (card instanceof HTMLElement) {
      toggleCardDetail(card);
    }
  });

  document.addEventListener('change', (event) => {
    const target = event.target;
    if (target instanceof HTMLInputElement && target.classList.contains('skill-checkbox')) {
      updateCardSelectionState(target);
    }
  });

  window.addEventListener('academicforge:locale-change', applyLocale);

  document.querySelectorAll<HTMLInputElement>('.skill-checkbox').forEach(updateCardSelectionState);
  skillCards.forEach((card) => setCardDetailState(card, card.classList.contains('is-expanded')));
  applyFilters();
  applyLocale();
</script>
